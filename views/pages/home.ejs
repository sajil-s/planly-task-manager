

<div class="grid md:grid-cols-[260px_1fr] gap-8">

<!-- LEFT SIDEBAR -->
<div class="space-y-6">

<div class="text-yellow-500 font-bold text-xl">
<%= new Date().toLocaleDateString() %>
</div>

<div class="bg-white p-6 rounded-xl shadow text-center">

<div class="text-3xl font-bold text-indigo-500">
<%= percentage %>%
</div>

<p class="text-gray-500 text-sm">Complete</p>

</div>

</div>


<!-- RIGHT SIDE -->
<div class="space-y-6">

<!-- ADD TASK -->
<div class="bg-white p-6 rounded-xl shadow">

<h2 class="text-lg font-semibold mb-4">Add New Task</h2>

<form action="/task" method="POST" class="space-y-4">

<input
type="text"
name="title"
placeholder="Task title"
required
class="w-full border rounded px-3 py-2"
/>

<input
type="text"
name="description"
placeholder="Task description"
class="w-full border rounded px-3 py-2"
/>

<select name="priority" class="border rounded px-3 py-2">
<option value="LOW">LOW</option>
<option value="MEDIUM">MEDIUM</option>
<option value="HIGH">HIGH</option>
</select>

<button
type="submit"
class="w-full bg-blue-500 text-white py-2 rounded"
>
Add Task
</button>

</form>

</div>


<!-- TASK LIST -->
<div class="bg-white p-6 rounded-xl shadow">

<h2 class="text-lg font-semibold mb-4">My Tasks</h2>

<ul class="space-y-4">

<% tasks.forEach(task => { %>

<li class="flex items-center gap-3 p-3 border rounded-lg <%= task.compleated ? 'line-through text-gray-400' : '' %>">

<form action="/toggle/<%= task.id %>" method="POST">
<input type="checkbox"
onchange="this.form.submit()"
<%= task.compleated ? "checked" : "" %>>
</form>

<div class="flex-1">

<span class="font-semibold">
<%= task.title %>
</span>

<p class="text-sm text-gray-500">
<%= task.descreption %>
</p>

</div>

<span class="text-xs px-2 py-1 rounded text-white
<%= task.priority === 'HIGH' ? 'bg-red-400' :
task.priority === 'MEDIUM' ? 'bg-yellow-400' :
'bg-green-400' %>">

<%= task.priority %>

</span>

<form action="/delete/<%=task.id%>" method="POST">
<button class="text-xs bg-red-400 px-2 py-1 rounded text-white">
Delete
</button>
</form>

</li>

<% }) %>

</ul>

</div>

</div>

</div>